generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum Role {
  EMPLOYEE
  MANAGER
  ADMIN
}

enum UomType {
  NUMERIC
  PERCENTAGE
  TIMELINE
  ZERO_BASED
}

enum GoalStatus {
  DRAFT
  PENDING
  APPROVED
  RETURNED
  COMPLETED
}

enum CyclePhase {
  GOAL_SETTING
  Q1_CHECKIN
  Q2_CHECKIN
  Q3_CHECKIN
  Q4_CHECKIN
  CLOSED
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  name          String
  role          Role     @default(EMPLOYEE)
  managerId     String?
  manager       User?    @relation("reports", fields: [managerId], references: [id])
  directReports User[]   @relation("reports")
  goals         Goal[]   @relation("EmployeeGoals")
  ownedGoals    Goal[]   @relation("PrimaryOwner")
  auditLogs     AuditLog[]
}

model Cycle {
  id        String     @id @default(uuid())
  name      String
  startDate DateTime
  endDate   DateTime
  phase     CyclePhase @default(GOAL_SETTING)
  isActive  Boolean    @default(false)
  goals     Goal[]
}

model Goal {
  id             String      @id @default(uuid())
  employeeId     String
  employee       User        @relation("EmployeeGoals", fields: [employeeId], references: [id])
  cycleId        String?
  cycle          Cycle?      @relation(fields: [cycleId], references: [id])
  thrustArea     String
  title          String
  description    String?
  uom            UomType
  target         Float
  weightage      Float       // must be >= 10; SUM per employee must = 100
  status         GoalStatus  @default(DRAFT)
  locked         Boolean     @default(false)
  returnReason   String?
  isShared       Boolean     @default(false)
  primaryOwnerId String?
  primaryOwner   User?       @relation("PrimaryOwner", fields: [primaryOwnerId], references: [id])
  updates        GoalUpdate[]
}

model GoalUpdate {
  id            String   @id @default(uuid())
  goalId        String
  goal          Goal     @relation(fields: [goalId], references: [id])
  quarter       String   // "Q1" | "Q2" | "Q3" | "Q4"
  achievement   Float
  statusUpdate  String   // "NOT_STARTED" | "ON_TRACK" | "COMPLETED"
  comment       String?  // manager check-in comment
  progressScore Float?   // computed by backend
  createdAt     DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  entityType String   // "Goal" | "GoalUpdate"
  entityId   String
  action     String   // "APPROVE" | "RETURN" | "UNLOCK" | "UPDATE" | "CREATE" | "DELETE"
  oldValue   Json?
  newValue   Json?
  timestamp  DateTime @default(now())
}
